ENVIRONMENT=production

HOST=0.0.0.0
PORT=8000

# Public API URL used by API responses and processor key URI generation
API_BASE_URL=https://mist-api.your-domain.com
HLS_KEY_BASE_URL=https://mist-api.your-domain.com

# Database and queue
DATABASE_URL=postgresql://user:password@db-host:5432/mist_db?sslmode=require
REDIS_URL=redis://default:password@redis-host:6379/0
CELERY_BROKER_URL=redis://default:password@redis-host:6379/0
CELERY_RESULT_BACKEND=redis://default:password@redis-host:6379/0

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-bucket-name

# Frontend origin(s) allowed by CORS
CLIENT_URLS=https://mist-web.your-domain.com

# Auth secrets
SECRET_KEY=generate-a-long-random-secret

LOG_LEVEL=INFO
